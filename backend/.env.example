# MongoDB
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/paperlens

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=paperlens
PINECONE_ENVIRONMENT=us-east-1

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/callback

# JWT Authentication
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Semantic Scholar (optional)
SEMANTIC_SCHOLAR_API_KEY=optional_semantic_scholar_api_key

# Frontend
FRONTEND_URL=http://localhost:5173
